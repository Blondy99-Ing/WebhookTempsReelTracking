{
  "name": "proxym-tracking-bridge",
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",

    "start:partner": "node src/index.js",
    "dev:partner": "nodemon src/index.js",

